{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bank-of-america-clone",
  "compatibility_date": "2026-07-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "bank-of-america.mybrandmint.in",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
